#!/usr/bin/env bash


SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/athos-utils.sh"

check_deps "gum" "fzf"

show_main_menu() {
  show_logo

  local choice
  choice=$(printf "%s\n" \
    "󰏗  Install Arch Package" \
    "󰏗  Install AUR Package" \
    "  Install Web App" \
    "---" \
    "🗑  Remove Arch Package" \
    "🗑  Remove AUR Package" \
    "🗑  Remove Web App" \
    "---" \
    "󰈔  Quit" \
    | gum choose --header "What would you like to do?" --height 15)

  case "$choice" in
    *"Install Arch Package")
      athos-pkg-install || true
      ;;
    *"Install AUR Package")
      athos-pkg-aur-install || true
      ;;
    *"Install Web App")
      athos-webapp-install || true
      ;;
    *"Remove Arch Package")
      athos-pkg-remove || true
      ;;
    *"Remove AUR Package")
      athos-pkg-aur-remove || true
      ;;
    *"Remove Web App")
      athos-webapp-remove || true
      ;;
    *"Quit"|"")
      show_logo
      echo "Goodbye!"
      exit 0
      ;;
  esac
}

main() {
  while true; do
    show_main_menu
  done
}

main "$@"
