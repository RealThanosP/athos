#!/usr/bin/env bash

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/athos-utils.sh"

check_deps "gum" "fzf"

show_logo
echo "Removing Web App..."
echo "Press Ctrl+Q to return to menu"
echo

app_dir="$HOME/.local/share/applications"
icon_dir="$HOME/.local/share/athos/icons"

apps=$(grep -l "athos-launch-webapp" "$app_dir"/*.desktop 2>/dev/null | xargs -I{} basename {} .desktop | sort)

if [[ -z "$apps" ]]; then
    echo "No web apps found."
    show_done
    exit 0
fi

selected=$(echo "$apps" | fzf --multi --preview "cat $app_dir/{1}.desktop" --preview-label='ctrl-q: quit, tab: multi-select' --bind 'ctrl-q:abort' --color 'pointer:green,marker:green')

if [[ -z "$selected" ]]; then
    exit 0
fi

while IFS= read -r app; do
    rm -f "$app_dir/$app.desktop"
    rm -f "$icon_dir/$app.png"
    echo "Removed $app"
done <<< "$selected"

show_done
