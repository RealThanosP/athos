#!/usr/bin/env bash

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/athos-utils.sh"

check_deps "gum" "curl"

show_logo
echo "Creating Web App..."
echo "Press Ctrl+C to exit"
echo

icon_dir="$HOME/.local/share/athos/icons"
app_dir="$HOME/.local/share/applications"
mkdir -p "$icon_dir"
mkdir -p "$app_dir"

app_name=$(gum input --prompt "Name> " --placeholder "My favorite web app")
exit_code=$?

if ((exit_code != 0)) || [[ -z $app_name ]]; then
    exit 0
fi

app_url=$(gum input --prompt "URL> " --placeholder "https://example.com")
exit_code=$?

if ((exit_code != 0)) || [[ -z $app_url ]]; then
    exit 0
fi

if [[ ! $app_url =~ ^[a-zA-Z][a-zA-Z0-9+.-]*: ]]; then
    app_url="https://$app_url"
fi

favicon_url="https://www.google.com/s2/favicons?domain=${app_url}&sz=128"
icon_path="$icon_dir/$app_name.png"

if ! curl -fsSL -o "$icon_path" "$favicon_url" || [[ ! -s "$icon_path" ]]; then
    icon_ref=$(gum input --prompt "Icon URL> " --placeholder "Could not fetch favicon automatically. Enter PNG icon URL")
    exit_code=$?
    if ((exit_code != 0)) || [[ -z $icon_ref ]]; then
        exit 0
    fi
    if ! curl -fsSL -o "$icon_path" "$icon_ref" || [[ ! -s "$icon_path" ]]; then
        echo "Error: Failed to download icon"
        exit 1
    fi
fi

exec_command="athos-launch-webapp $app_url"
desktop_file="$app_dir/$app_name.desktop"

cat >"$desktop_file" <<EOF
[Desktop Entry]
Version=1.0
Name=$app_name
Comment=$app_name
Exec=$exec_command
Terminal=false
Type=Application
Icon=$icon_path
StartupNotify=true
Categories=System;Web;
Keywords=webapp;
EOF

chmod +x "$desktop_file"

echo
echo -e "You can now find $app_name using the app launcher"
show_done
trap - SIGINT
