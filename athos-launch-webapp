#!/usr/bin/env bash

set -e

if [[ -z "$1" ]]; then
    echo "Usage: athos-launch-webapp <url>"
    exit 1
fi

url="$1"

if [[ ! "$url" =~ ^[a-zA-Z][a-zA-Z0-9+.-]*: ]]; then
    url="https://$url"
fi

if command -v xdg-open &>/dev/null; then
    exec xdg-open "$url"
else
    echo "Error: xdg-open not found. Could not open link."
    exit 1
fi
